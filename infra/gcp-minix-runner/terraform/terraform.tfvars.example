project_id           = "my-gcp-project"
region               = "us-central1"
zone                 = "us-central1-a"
name_prefix          = "minix-sem"
artifact_bucket_name = "my-minix-sem-runner-artifacts"

# Prepared image and patch bundle. See ../MINIX_IMAGE_CONTRACT.md.
minix_image_uri  = "gs://my-minix-sem-runner-artifacts/inputs/minix.img"
patch_bundle_uri = "gs://my-minix-sem-runner-artifacts/inputs/minix-patches.tar.gz"

# N2 is a safe default for nested virtualization. Do not use E2, AMD, Arm,
# memory-optimized, or H4D machine families.
runner_machine_type = "n2-standard-4"

# Optional. Set after building and pushing status-app.
status_image      = ""
public_status_app = false
